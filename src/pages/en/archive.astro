---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScriptCard from '../../components/ScriptCard.astro';
import { archivedScripts } from '../../lib/scripts';

const archived = archivedScripts();
---

<BaseLayout title="Archive · NWAFU Scripts" lang="en" currentPath="/en/archive/">
  <section class="hero page-hero">
    <p class="eyebrow">Archive</p>
    <h1>Archived scripts</h1>
    <p>Scripts that no longer belong on the front page can stay here with their notes and old install paths.</p>
  </section>
  <section class="section">
    {archived.length > 0 ? <div class="grid">{archived.map((script) => <ScriptCard script={script} lang="en" />)}</div> : <div class="empty">No archived scripts.</div>}
  </section>
</BaseLayout>
