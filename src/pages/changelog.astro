---
import BaseLayout from '../layouts/BaseLayout.astro';
import changelog from '../generated/changelog.json';
import { scripts } from '../lib/scripts';

type ChangelogEntry = (typeof changelog)[number];

const scriptNames = new Map(scripts.map((script) => [script.slug, script.name]));
---

<BaseLayout title="更新日志 · NWAFU Scripts" currentPath="/changelog/">
  <section class="hero page-hero compact-hero">
    <p class="eyebrow">Changelog</p>
    <h1>更新日志</h1>
    <p>站点和脚本的公开变更记录。</p>
  </section>
  <section class="section">
    <ul class="changelog-list">
      {changelog.map((entry: ChangelogEntry) => (
        <li>
          <div class="changelog-date">{entry.date}</div>
          <div class="changelog-body">
            <strong>{entry.title}</strong>
            <p><a href={entry.url}>{entry.sha}</a></p>
            {entry.scripts.length > 0 && (
              <div class="tag-list changelog-tags" aria-label="相关脚本">
                {entry.scripts.map((slug) => <span>{scriptNames.get(slug) || slug}</span>)}
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
